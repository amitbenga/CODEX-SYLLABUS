# Google Cloud project NUMBER (not the project id). Required.
NOTEBOOKLM_PROJECT=123456789012

# Data location for your NotebookLM Enterprise instance. Defaults to "global".
# NOTEBOOKLM_LOCATION=global

# Optional: provide a pre-minted OAuth access token instead of using
# Application Default Credentials. Get one with:
#   gcloud auth print-access-token
# NOTEBOOKLM_ACCESS_TOKEN=ya29....

# Optional: override the Discovery Engine API version. Defaults to "v1alpha".
# NOTEBOOKLM_API_VERSION=v1alpha
